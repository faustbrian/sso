{
    "name": "cline/sso",
    "description": "Laravel-first SSO, OIDC, SAML, and SCIM primitives with package-owned persistence and adapter seams.",
    "license": "MIT",
    "keywords": [
        "auth",
        "laravel",
        "oidc",
        "php",
        "saml",
        "scim",
        "sso"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "ext-dom": "*",
        "ext-openssl": "*",
        "cline/jwt": "^1.0",
        "cline/morphism": "^2.0.1",
        "cline/variable-keys": "^2.0.2",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "phpseclib/phpseclib": "^3.0.49",
        "spatie/laravel-package-tools": "^1.93.0"
    },
    "require-dev": {
        "cline/coding-standard": "^2.0.1",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.9",
        "symfony/var-dumper": "^6.0 || ^7.4.6 || ^8.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\SSO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Sso": "Cline\\SSO\\Facades\\Sso"
            },
            "providers": [
                "Cline\\SSO\\SsoServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "vendor/bin/ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "vendor/bin/ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
